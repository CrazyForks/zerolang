type Pair<T: Type, U: Type> {
    left: T,
    right: U,
}

pub fn main(world: World) -> Void raises {
    let pair: Pair<i32, u8> = Pair { left: 7, right: 9_u8 }
    if pair.left == 7 && pair.right == 9_u8 {
        check world.out.write("generic shape multi ok\n")
    } else {
        check world.out.write("generic shape multi broke\n")
    }
}
