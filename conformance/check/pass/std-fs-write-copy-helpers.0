pub fn main(world: World) -> Void raises {
    let fs: Fs = std.fs.host()
    var buffer: [8]u8 = [0_u8; 8]
    if std.fs.writeFile(fs, "/tmp/zero-stdlib-write-helper.txt", "ok\n") {
        if std.fs.copyFile("/tmp/zero-stdlib-write-helper.txt", "/tmp/zero-stdlib-copy-helper.txt", buffer) {
            check world.out.write("std fs write copy helpers\n")
        }
    }
}
